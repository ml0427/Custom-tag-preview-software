{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "comic-manager",
  "version": "0.1.0",
  "identifier": "com.comic.manager.software",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Custom Tag Preview v0.41 · 2026-05-02 23:52",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: https://tauri.localhost http://localhost:5173 ws://localhost:5173; img-src 'self' comic-cache: data: blob: https://tauri.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' http://localhost:5173 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
